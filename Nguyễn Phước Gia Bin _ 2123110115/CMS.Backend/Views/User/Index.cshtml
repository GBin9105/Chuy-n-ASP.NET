@model IEnumerable<CMS.Data.Entities.User>

@{
    ViewData["Title"] = "Quản Lý Thành Viên";
}

<div class="container mt-4">
    <h2 class="text-primary text-center mb-4 fw-bold">DANH SÁCH THÀNH VIÊN</h2>

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-success"><i class="bi bi-person-plus"></i> Thêm thành viên mới</a>
    </div>

    <table class="table table-bordered table-hover text-center shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Tài khoản</th>
                <th>Họ và tên</th>
                <th>Quyền hạn</th>
                <th style="width: 150px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="font-weight-bold">@item.Id</td>
                    <td>@item.Username</td>
                    <td>@item.FullName</td>
                    <td><span class="badge bg-info text-dark">@item.Role</span></td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"
                           onclick="return confirm('Xác nhận xóa thành viên này?')">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>