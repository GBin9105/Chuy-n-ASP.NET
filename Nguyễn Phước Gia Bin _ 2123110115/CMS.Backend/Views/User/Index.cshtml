@model IEnumerable<CMS.Data.Entities.User>

@{
    ViewData["Title"] = "Quản Lý Thành Viên";
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark m-0">QUẢN LÝ THÀNH VIÊN</h2>
        <button class="btn btn-success btn-sm">+ Thêm thành viên mới</button>
    </div>

    <table class="table table-bordered table-striped text-center shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Tên Đăng Nhập</th>
                <th>Họ Và Tên</th>
                <th>Quyền Hạn</th>
                <th>Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td class="font-weight-bold text-secondary">@item.Username</td>
                    <td>@item.FullName</td>
                    <td>
                        @if (item.Role == "Admin")
                        {
                            <span class="badge bg-danger p-2 text-white">Admin</span>
                        }
                        else if (item.Role == "Editor")
                        {
                            <span class="badge bg-info p-2 text-white">Editor</span>
                        }
                        else
                        {
                            <span class="badge bg-warning p-2 text-dark">@item.Role</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-warning btn-sm mx-1">Sửa</button>
                        <button class="btn btn-danger btn-sm mx-1">Xóa</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>