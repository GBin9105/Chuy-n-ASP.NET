@model CMS.Data.Entities.User

@{
    ViewData["Title"] = "Thêm Thành Viên";
}

<div class="container mt-4">
    <h2 class="text-primary text-center fw-bold">THÊM THÀNH VIÊN</h2><hr />
    <form asp-action="Create" method="post">
        <div class="mb-3"><label class="fw-bold">Tài khoản:</label><input asp-for="Username" class="form-control" required /></div>
        <div class="mb-3"><label class="fw-bold">Họ và tên:</label><input asp-for="FullName" class="form-control" required /></div>
        <div class="mb-3"><label class="fw-bold">Mật khẩu:</label><input asp-for="PasswordHash" type="password" class="form-control" required /></div>
        <div class="mb-3"><label class="fw-bold">Phân quyền (Role):</label><input asp-for="Role" class="form-control" placeholder="Admin hoặc Editor" required /></div>
        <button type="submit" class="btn btn-success">Lưu thành viên</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
    </form>
</div>