@model CMS.Data.Entities.User

@{
    ViewData["Title"] = "Sửa Thành Viên";
}

<div class="container mt-4">
    <h2 class="text-warning text-center fw-bold">SỬA THÀNH VIÊN</h2><hr />
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="mb-3"><label class="fw-bold">Tài khoản:</label><input asp-for="Username" class="form-control" required /></div>
        <div class="mb-3"><label class="fw-bold">Họ và tên:</label><input asp-for="FullName" class="form-control" required /></div>
        <div class="mb-3"><label class="fw-bold">Mật khẩu:</label><input asp-for="PasswordHash" class="form-control" required /></div>
        <div class="mb-3"><label class="fw-bold">Phân quyền (Role):</label><input asp-for="Role" class="form-control" required /></div>
        <button type="submit" class="btn btn-warning">Cập nhật</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
    </form>
</div>