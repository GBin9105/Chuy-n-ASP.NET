@model IEnumerable<CMS.Data.Entities.Category>

@{
    ViewData["Title"] = "Danh Sách Danh Mục";
}

<h2 class="text-primary text-center my-4">DANH SÁCH DANH MỤC</h2>

<table class="table table-bordered table-striped text-center">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Tên danh mục</th>
            <th>Mô tả</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Description</td>
            </tr>
        }
    </tbody>
</table>