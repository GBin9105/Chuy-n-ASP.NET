@model CMS.Data.Entities.Post

@{
    ViewData["Title"] = "Thêm Bài Viết";
}

<div class="container mt-4">
    <h2 class="text-primary text-center fw-bold">THÊM BÀI VIẾT MỚI</h2>
    <hr />

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label class="form-label fw-bold">Tiêu đề bài viết:</label>
            <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề..." required />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Thuộc danh mục:</label>
            <select asp-for="CategoryId" asp-items="ViewBag.CategoryList" class="form-select" required>
                <option value="">-- Vui lòng chọn danh mục --</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Link ảnh minh họa (ImageUrl):</label>
            <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Nội dung bài viết:</label>
            <textarea asp-for="Content" class="form-control" rows="6" placeholder="Nhập nội dung chi tiết..."></textarea>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-success">Lưu bài viết</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
        </div>
    </form>
</div>