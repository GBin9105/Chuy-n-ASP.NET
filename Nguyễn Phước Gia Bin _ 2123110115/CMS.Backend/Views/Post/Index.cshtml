@model IEnumerable<CMS.Data.Entities.Post>

@{
    ViewData["Title"] = "Danh Sách Bài Viết";
}

<h2 class="text-primary text-center my-4">DANH SÁCH BÀI VIẾT MỚI NHẤT</h2>

<div class="container">
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="@item.ImageUrl" class="card-img-top" alt="Thumbnail">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-primary font-weight-bold">@item.Title</h5>
                        <p class="card-text text-muted small">Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")</p>
                        <p class="card-text text-secondary text-truncate">@item.Content</p>
                        <a href="/Post/Details/@item.Id" class="btn btn-primary btn-sm mt-auto">Xem chi tiết</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>