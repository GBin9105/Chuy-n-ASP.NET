@model IEnumerable<CMS.Data.Entities.Post>

@{
    ViewData["Title"] = "Danh Sách Bài Viết";
}

<div class="container mt-4">
    <h2 class="text-primary text-center my-4 fw-bold">DANH SÁCH BÀI VIẾT MỚI NHẤT</h2>

    <div class="mb-4 text-start">
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Thêm bài viết mới
        </a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="@item.ImageUrl" class="card-img-top" alt="Thumbnail" style="height: 200px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-info text-dark mb-2 align-self-start">@item.Category?.Name</span>

                        <h5 class="card-title text-primary font-weight-bold">@item.Title</h5>
                        <p class="card-text text-muted small mb-1">Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")</p>
                        <p class="card-text text-secondary text-truncate">@item.Content</p>

                        <div class="mt-auto d-flex justify-content-between align-items-center pt-2">
                            <a href="/Post/Details/@item.Id" class="btn btn-primary btn-sm">Xem chi tiết</a>
                            <div>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>

                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm"
                                   onclick="return confirm('Bạn có chắc chắn muốn xóa bài viết này không?')">Xóa</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>