@model CMS.Data.Entities.Post

@{
    ViewData["Title"] = Model.Title;
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="text-dark mb-3">@Model.Title</h1>
            <p class="text-muted">Mã bài viết: #@Model.Id</p>
            <hr />
            <div class="lead text-secondary mb-4" style="line-height: 1.8;">
                @Model.Content
            </div>
            <a href="/Post" class="btn btn-outline-secondary">← Quay lại danh sách</a>
        </div>
    </div>
</div>