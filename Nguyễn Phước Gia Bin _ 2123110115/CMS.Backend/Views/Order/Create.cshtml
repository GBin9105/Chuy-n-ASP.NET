@model CMS.Data.Entities.Order

@{
    ViewData["Title"] = "Tạo Đơn Hàng Mới";
}

<div class="container mt-4">
    <h2 class="text-success text-center fw-bold">TẠO ĐƠN HÀNG MỚI</h2>
    <hr />

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label class="form-label fw-bold">Khách hàng:</label>
            <select asp-for="CustomerId" asp-items="ViewBag.CustomerList" class="form-select" required>
                <option value="">-- Vui lòng chọn khách hàng --</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Ngày đặt hàng:</label>
            <input asp-for="OrderDate" class="form-control" type="datetime-local" required />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Trạng thái đơn hàng:</label>
            <select asp-for="Status" class="form-select">
                <option value="0">Chờ duyệt</option>
                <option value="1">Đang giao</option>
                <option value="2">Đã giao thành công</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Ghi chú (Notes):</label>
            <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Nhập yêu cầu đặc biệt của khách hàng..."></textarea>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-success">Lưu đơn hàng</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
        </div>
    </form>
</div>